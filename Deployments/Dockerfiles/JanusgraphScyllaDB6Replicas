services:
  cassandra1:
    container_name: cassandra1
    image: cassandra:4.1
    restart: always
    environment:
      - CASSANDRA_SEEDS=cassandra1
      - CASSANDRA_CLUSTER_NAME=GRACECluster
      - CASSANDRA_DC=datacenter1
      - CASSANDRA_ENDPOINT_SNITCH=GossipingPropertyFileSnitch
      - MAX_HEAP_SIZE=8G
      - HEAP_NEWSIZE=2G
    healthcheck:
      test: ["CMD-SHELL", "nodetool status | grep UN"]
      interval: 10s
      timeout: 5s
      retries: 10
    ports:
      - "9042:9042"
  cassandra1-netem:
    image: gaiadocker/iproute2
    container_name: cassandra1-netem
    network_mode: "service:cassandra1"   # share net namespace with cassandra1
    cap_add:
      - NET_ADMIN
    volumes:
      - ../setup-latency.sh:/usr/local/bin/setup-latency.sh
    entrypoint: ["/bin/sh", "-c", "sleep 9999999"]

